# Copy relevant values into project root `.env` when using Docker Compose.
# DB credentials must match docker-compose.yml `mysql` service.

APP_NAME="Compliance Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Browser + Sanctum first-party requests (include Vite port if using --profile vite)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080,localhost:5173,127.0.0.1:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=laravel_secret

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log
MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
