{
  "info": {
    "name": "Compliance Management System API",
    "description": "Import this collection, set `base_url`, then **Auth → Login (Admin or Auditor)**. The **Exports (PDF System)** folder covers synchronous and queued PDF exports. For queued exports, run `php artisan queue:work` in a separate terminal (with `QUEUE_CONNECTION=database` in `.env`). See `docs/api.md` for full detail.",
    "_postman_id": "b5b31f2c-7f0b-4f74-9a6d-9b2c1b0e7f11",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token", "value": "" },
    { "key": "template_id", "value": "" },
    { "key": "question_id", "value": "" },
    { "key": "checklist_id", "value": "" },
    { "key": "export_uuid", "value": "" },
    { "key": "download_url", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\",\n  \"device_name\": \"postman\"\n}\n",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.success && json?.data?.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (Auditor)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"auditor@example.com\",\n  \"password\": \"password\",\n  \"device_name\": \"postman\"\n}\n",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.success && json?.data?.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/me", "host": ["{{base_url}}"], "path": ["api", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/logout", "host": ["{{base_url}}"], "path": ["api", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Templates (Admin)",
      "item": [
        {
          "name": "List templates",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/templates?per_page=15", "host": ["{{base_url}}"], "path": ["api", "templates"], "query": [{ "key": "per_page", "value": "15" }] }
          }
        },
        {
          "name": "Create template",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/templates", "host": ["{{base_url}}"], "path": ["api", "templates"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Demo Template\",\n  \"description\": \"Created via API\",\n  \"status\": \"draft\"\n}\n",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.success && json?.data?.id) {",
                  "  pm.collectionVariables.set('template_id', String(json.data.id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Questions (Admin)",
      "item": [
        {
          "name": "Create question (choice)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/templates/{{template_id}}/questions", "host": ["{{base_url}}"], "path": ["api", "templates", "{{template_id}}", "questions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question_text\": \"Pick one\",\n  \"answer_type\": \"select\",\n  \"required\": true,\n  \"sort_order\": 1,\n  \"options\": [\n    {\"value\": \"a\", \"label\": \"Option A\"},\n    {\"value\": \"b\", \"label\": \"Option B\"}\n  ]\n}\n",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.success && json?.data?.id) {",
                  "  pm.collectionVariables.set('question_id', String(json.data.id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Checklists (Auditor)",
      "item": [
        {
          "name": "List my checklists",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/checklists", "host": ["{{base_url}}"], "path": ["api", "checklists"] }
          }
        },
        {
          "name": "Start checklist",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/checklists/start/{{template_id}}", "host": ["{{base_url}}"], "path": ["api", "checklists", "start", "{{template_id}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.success && json?.data?.id) {",
                  "  pm.collectionVariables.set('checklist_id', String(json.data.id));",
                  "}",
                  "if (json?.success && json?.data?.template_id) {",
                  "  pm.collectionVariables.set('template_id', String(json.data.template_id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Save draft (map of question_id -> value)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/checklists/{{checklist_id}}/save-draft", "host": ["{{base_url}}"], "path": ["api", "checklists", "{{checklist_id}}", "save-draft"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": {\n    \"123\": \"some text\",\n    \"124\": 12,\n    \"125\": \"2026-05-09\",\n    \"126\": [\"a\", \"b\"]\n  }\n}\n",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Complete checklist",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/checklists/{{checklist_id}}/complete", "host": ["{{base_url}}"], "path": ["api", "checklists", "{{checklist_id}}", "complete"] }
          }
        }
      ]
    },
    {
      "name": "Reports (Admin)",
      "item": [
        {
          "name": "Reports (filters)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/reports?date_from=&date_to=&template_id=&auditor_id=&q=&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "reports"],
              "query": [
                { "key": "date_from", "value": "" },
                { "key": "date_to", "value": "" },
                { "key": "template_id", "value": "" },
                { "key": "auditor_id", "value": "" },
                { "key": "q", "value": "" },
                { "key": "per_page", "value": "15" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Exports (PDF System)",
      "description": "Unified PDF export API. Responses may be **200 + PDF** (immediate) or **202 + JSON** (queued). Start `php artisan queue:work` before testing queued flows.",
      "item": [
        {
          "name": "Create PDF export (unified)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json, application/pdf" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/exports/pdf",
              "host": ["{{base_url}}"],
              "path": ["api", "exports", "pdf"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"export_type\": \"compliance_snapshot\",\n  \"filters\": {\n    \"detail\": \"standard\",\n    \"date_from\": null,\n    \"date_to\": null\n  }\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "description": "**Admin only** for this example body. Returns **200** with PDF bytes if immediate, or **202** JSON if queued. When **202**, Tests save `export_uuid`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const ct = pm.response.headers.get('Content-Type') || '';",
                  "if (ct.includes('application/json')) {",
                  "  try {",
                  "    const json = pm.response.json();",
                  "    if (pm.response.code === 202 && json?.data?.export_uuid) {",
                  "      pm.collectionVariables.set('export_uuid', json.data.export_uuid);",
                  "    }",
                  "  } catch (e) {}",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List exports",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/exports",
              "host": ["{{base_url}}"],
              "path": ["api", "exports"]
            },
            "description": "Recent exports for the current user. Admins may add `?all=1`."
          }
        },
        {
          "name": "Get export by UUID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/exports/{{export_uuid}}",
              "host": ["{{base_url}}"],
              "path": ["api", "exports", "{{export_uuid}}"]
            },
            "description": "Poll until `status` is `completed` or `failed`. Tests save `download_url` when present."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const u = json?.data?.download_url;",
                  "  if (u) pm.collectionVariables.set('download_url', u);",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Download completed PDF",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/pdf, application/json" }
            ],
            "url": {
              "raw": "{{download_url}}",
              "variable": []
            },
            "description": "Run **Get export by UUID** first so `download_url` is set (full signed URL). Uses collection Bearer auth. If `download_url` is empty, poll until export is `completed`."
          }
        }
      ]
    }
  ]
}

